# ===== CHAM Agent Environment Variables =====
# Copy this to .env and fill in your values.

# MongoDB connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/cham-agent

# Google OAuth credentials (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Session secret (generate a random 64-char hex string)
SESSION_SECRET=your-random-session-secret

# ===== LLM Provider API Keys =====
# At least one is required. The system uses a fallback chain.
# Configure order with LLM_PROVIDER_ORDER (default: groq,gemini,openai)

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Groq — free tier (https://console.groq.com/keys)
GROQ_API_KEY=gsk_your-groq-api-key

# OpenAI — fallback (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-your-openai-api-key

# LLM provider fallback order (comma-separated)
# Options: groq, gemini, openai
LLM_PROVIDER_ORDER=groq,gemini,openai

# ===== Judge0 Code Sandbox =====
# For dynamic code execution (Layer 1 of CHAM)
# Self-hosted: just set the URL, no key needed
# RapidAPI: set both URL and key
JUDGE0_API_URL=http://localhost:2358
# JUDGE0_API_KEY=your-rapidapi-key

# ===== Optional =====
# Google OAuth callback URL
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Dev login passcode (only works when NODE_ENV != production)
# DEV_PASSCODE=1234

# Node environment
# NODE_ENV=development
